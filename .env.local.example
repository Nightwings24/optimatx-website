# Copy this file to `.env.local` and fill in real values.
# All vars are prefixed NEXT_PUBLIC_ because the site is a static export -
# forms and embeds run in the browser, so there is no server to read a
# private variable.

# Form submissions (Contact, Join, and later POTW / event registration).
# Create a free form at https://formspree.io (or https://web3forms.com) and
# paste its endpoint URL here.
#   Formspree:  https://formspree.io/f/xxxxxxxx
#   Web3Forms:  https://api.web3forms.com/submit   (then set the access key below)
NEXT_PUBLIC_FORM_ENDPOINT=

# Web3Forms only: your access key (leave blank if using Formspree).
NEXT_PUBLIC_WEB3FORMS_KEY=

# Optional: an embeddable Google Calendar src URL for the Events page.
NEXT_PUBLIC_GCAL_SRC=

# Optional: a Google Maps embed URL for the Contact page.
NEXT_PUBLIC_MAP_SRC=

# Optional: Supabase project for the POTW leaderboard. Unset, the answer box
# falls back to an offline self-check. Use the PUBLISHABLE key (safe in the
# browser), never the secret key. Setup: supabase/README.md
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
